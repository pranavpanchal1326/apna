{
  "expo": {
    "name": "apna",
    "slug": "apna",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#080C14"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.apna.android"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080C14"
      },
      "package": "app.apna.android",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#080C14",
          "image": "./assets/splash.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "apna needs your location to show friends on the map.",
          "locationWhenInUsePermission": "apna needs your location to show friends on the map."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "apna needs camera access to scan QR codes and add memories."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "apna needs photo access to add memories to your group."
        }
      ],
      "@sentry/react-native",
      "expo-status-bar"
    ],
    "extra": {
      "firebaseApiKey": "REPLACE_IN_EAS_SECRETS",
      "firebaseAuthDomain": "REPLACE_IN_EAS_SECRETS",
      "firebaseProjectId": "REPLACE_IN_EAS_SECRETS",
      "firebaseStorageBucket": "REPLACE_IN_EAS_SECRETS",
      "firebaseMessagingSenderId": "REPLACE_IN_EAS_SECRETS",
      "firebaseAppId": "REPLACE_IN_EAS_SECRETS",
      "firebaseDatabaseUrl": "REPLACE_IN_EAS_SECRETS",
      "mapboxToken": "REPLACE_IN_EAS_SECRETS",
      "posthogKey": "REPLACE_IN_EAS_SECRETS",
      "sentryDsn": "REPLACE_IN_EAS_SECRETS",
      "appEnv": "development"
    },
    "eas": {
      "projectId": "FILL_AFTER_EAS_INIT"
    }
  }
}
