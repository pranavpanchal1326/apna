# .env.example — copy to .env and fill in values
# NEVER commit .env to git — it's already in .gitignore from Prompt 0.1

# Firebase (from Firebase Console → Project Settings → Your apps)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Sentry (from sentry.io → Project → Settings → Client Keys)
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# PostHog (from posthog.com → Project Settings → API Keys)
POSTHOG_API_KEY=

# Mapbox (from account.mapbox.com → Access tokens) — Phase 3
MAPBOX_ACCESS_TOKEN=
EXPO_PUBLIC_MAPBOX_TOKEN=

# Weather (OpenWeatherMap One Call API 3.0)
OPENWEATHER_API_KEY=
EXPO_PUBLIC_OPENWEATHER_API_KEY=
