rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper to check if user is a member of the group in Firestore
    function isGroupMember(groupId) {
      return request.auth != null &&
        request.auth.uid in firestore.get(/databases/(default)/documents/groups/$(groupId)).data.memberIds;
    }

    // Helper to check if user is an admin of the group in Firestore
    function isGroupAdmin(groupId) {
      return request.auth != null &&
        request.auth.uid in firestore.get(/databases/(default)/documents/groups/$(groupId)).data.adminIds;
    }

    // ── Memory photos ────────────────────────────────────────────────────
    // Only group members, max 10MB per file. Delete restricted to admins.
    match /groups/{groupId}/memories/{allPaths=**} {
      allow read:   if isGroupMember(groupId);
      allow create: if isGroupMember(groupId)
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if isGroupAdmin(groupId);
    }

    // ── Expense receipts ─────────────────────────────────────────────────
    // Only group members, max 10MB per file
    match /groups/{groupId}/receipts/{allPaths=**} {
      allow read:  if isGroupMember(groupId);
      allow write: if isGroupMember(groupId)
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ── Group cover photo ─────────────────────────────────────────────────
    // Read: group members. Write: group admin, max 3MB limit
    match /groups/{groupId}/cover/{allPaths=**} {
      allow read:  if isGroupMember(groupId);
      allow write: if isGroupAdmin(groupId)
        && request.resource.size < 3 * 1024 * 1024;
    }

    // ── User avatars ──────────────────────────────────────────────────────
    // Authenticated read, 1MB limit, own uid only
    match /users/{userId}/avatar/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 1 * 1024 * 1024;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
